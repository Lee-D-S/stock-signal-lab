# ─────────────────────────────────────────────
# 한국투자증권 — 모의투자
# ─────────────────────────────────────────────
KIS_MOCK_APP_KEY=
KIS_MOCK_APP_SECRET=
KIS_MOCK_ACCOUNT_NO=   # 모의계좌번호 (예: 5012345678)

# ─────────────────────────────────────────────
# 한국투자증권 — 실거래
# ─────────────────────────────────────────────
KIS_REAL_APP_KEY=
KIS_REAL_APP_SECRET=
KIS_REAL_ACCOUNT_NO=   # 실계좌번호 (예: 5012345678)

# true=모의투자, false=실거래 (이것만 바꾸면 전환됨)
KIS_IS_MOCK=true

# ─────────────────────────────────────────────
# 텔레그램
# ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────
# Google Gemini API
# ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─────────────────────────────────────────────
# DART 전자공시 API (재무제표 스크리닝용)
# https://opendart.fss.or.kr 에서 발급
# ─────────────────────────────────────────────
DART_API_KEY=

# ─────────────────────────────────────────────
# 대시보드
# ─────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000

# ─────────────────────────────────────────────
# 매매 설정
# ─────────────────────────────────────────────
MAX_ORDER_AMOUNT=100000       # 1회 최대 주문 금액 (원)
MAX_POSITIONS=10              # 최대 보유 종목 수
NEWS_CRAWL_INTERVAL_MIN=10    # 뉴스 크롤링 주기 (분)
STOP_LOSS_PCT=-0.05           # 손절 기준 (-5%)
TAKE_PROFIT_PCT=0.10          # 익절 기준 (+10%)
